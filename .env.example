# === Telegram ===
TELEGRAM_BOT_TOKEN=your_token_here
TARGET_CHAT_ID=                          # опционально, ограничение доступа

# === Gemini CLI ===
GEMINI_MODEL=gemini-2.5-flash            # модель по умолчанию
GEMINI_APPROVAL_MODE=yolo                # default / auto_edit / yolo / plan
# GEMINI_WORKING_DIR=/home/user/projects # рабочая директория CLI (по умолчанию базовая папка пользователя)
GEMINI_CLI_TIMEOUT=300                   # таймаут в секундах
GEMINI_SANDBOX=false                     # запуск в изолированной среде

# === Gemini API (для голосовых сообщений) ===
GEMINI_API_KEY=                          # API ключ для транскрибации

# === Стриминг ===
STREAM_UPDATE_INTERVAL=1.5              # секунды между editMessageText

# === Аппрув ===
APPROVAL_TIMEOUT=120                     # секунды до авто-отклонения

# === Логирование ===
LOG_LEVEL=INFO                           # DEBUG / INFO / WARNING / ERROR
