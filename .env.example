# === Telegram ===
TELEGRAM_BOT_TOKEN=your_token_here
TARGET_CHAT_ID=                          # опционально, ограничение доступа

# === Gemini CLI ===
GEMINI_MODEL=gemini-3-flash-preview            # модель по умолчанию
GEMINI_APPROVAL_MODE=yolo                # default / auto_edit / yolo / plan
# GEMINI_WORKING_DIR=/home/user/projects # рабочая директория CLI (по умолчанию базовая папка пользователя)
GEMINI_CLI_TIMEOUT=600                   # таймаут в секундах (600 = 10 минут для операций со skills)
GEMINI_SANDBOX=false                     # запуск в изолированной среде
GEMINI_STREAM_DEBUG=false                # подробные логи stream-json событий Gemini CLI
GEMINI_SOFT_FINALIZE_IDLE_SECONDS=90     # мягкое завершение, если result не пришёл, но файл уже готов
ARTIFACT_WATCH_INTERVAL=1.0              # интервал проверки готовности файлов во время выполнения
ARTIFACT_STABLE_SECONDS=5.0              # сколько секунд файл должен не меняться перед авто-отправкой

# === Gemini API (для голосовых сообщений) ===
GEMINI_API_KEY=                          # API ключ для транскрибации

# === Стриминг ===
STREAM_UPDATE_INTERVAL=1.5              # секунды между editMessageText

# === Аппрув ===
APPROVAL_TIMEOUT=120                     # секунды до авто-отклонения

# === Логирование ===
LOG_LEVEL=INFO                           # DEBUG / INFO / WARNING / ERROR
