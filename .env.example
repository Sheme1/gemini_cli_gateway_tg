# === Telegram ===
TELEGRAM_BOT_TOKEN=your_token_here
# Empty allows every chat that can reach the bot.
# One user/chat: TARGET_CHAT_ID=111111111
# Two users/chats: TARGET_CHAT_ID=111111111,222222222
# Groups and supergroups can have negative chat id values.
TARGET_CHAT_ID=

# === Gemini CLI runtime ===
GEMINI_BIN=gemini
GEMINI_MODEL=auto
GEMINI_TARGET_VERSION=0.39.1
GEMINI_SKIP_TRUST=true
GEMINI_APPROVAL_MODE=yolo
# Optional Gemini CLI 0.39.1 runtime flags.
# GEMINI_POLICY_PATHS=/home/your_user/.gemini/policies/gateway.toml
# GEMINI_ADMIN_POLICY_PATHS=/etc/gemini-cli/policies/org.toml
# GEMINI_ALLOWED_MCP_SERVER_NAMES=github,context7
# GEMINI_EXTENSIONS=none
GEMINI_SCREEN_READER=false
# GEMINI_WORKING_DIR=/home/your_user/projects
# GEMINI_INCLUDE_DIRECTORIES=/home/your_user/projects/shared,/home/your_user/docs
# GEMINI_ARTIFACT_ROOTS=/home/your_user/projects,/home/your_user/Downloads
GEMINI_CLI_TIMEOUT=600
# Max bytes for one stdout/stderr line from Gemini stream-json.
GEMINI_STREAM_READER_LIMIT_BYTES=8388608
GEMINI_SHUTDOWN_GRACE_SECONDS=5
GEMINI_SANDBOX=false
GEMINI_STREAM_DEBUG=false
GEMINI_SOFT_FINALIZE_IDLE_SECONDS=90
ARTIFACT_WATCH_INTERVAL=1.0
ARTIFACT_STABLE_SECONDS=5.0

# === Gemini API (voice transcription) ===
GEMINI_API_KEY=

# === Telegram streaming ===
# Live updates are sent as plain text. The final answer is rendered as safe
# Telegram HTML after the Gemini stream is complete.
STREAM_UPDATE_INTERVAL=1.5
STREAM_MIN_UPDATE_CHARS=120
STREAM_RETRY_MAX_DELAY=30

# === Prompt guard ===
PROMPT_WARN_CHARS=12000
PROMPT_MAX_CHARS=60000
PROMPT_CONFIRM_TIMEOUT=120

# === Usage limits ===
# 0 disables the limit.
USER_DAILY_TOKEN_LIMIT=0
GLOBAL_DAILY_TOKEN_LIMIT=0

# === Telegram polling ===
POLLING_TIMEOUT=10
POLLING_CONCURRENCY_LIMIT=4

# === Gateway state ===
GATEWAY_STATE_DIR=.gateway_state
# Continue the latest Gemini CLI project session when no persisted active session
# exists yet, for example right after upgrading from an older gateway version.
GATEWAY_SESSION_AUTO_RESUME_LATEST=true

# === Experimental multi-user workspaces ===
# Opt-in. Keeps one shared Gemini CLI auth/HOME, but gives each Telegram user
# a separate workspace, GEMINI.md, session project, and artifact search roots.
GATEWAY_EXPERIMENTAL_MULTI_USER_WORKSPACES=false
# Default when empty: <GATEWAY_STATE_DIR>/users
# GATEWAY_USER_WORKSPACES_DIR=/srv/gemini-gateway/users

# === Approval UI ===
APPROVAL_TIMEOUT=120

# === Logging ===
LOG_MODE=normal
# Legacy override. Leave empty unless you need a specific Python logging level.
LOG_LEVEL=
